<%# Hero Banner %>
<div class="hero-banner d-flex align-items-center">
  <div class="container text-center">
    <h1 class="display-3 fw-bold text-white mb-3">
      The World's Finest <span class="gold-text">Cinema Collection</span>
    </h1>
    <p class="lead text-muted mb-4">Premium art prints from movies and TV's greatest moments</p>
    <%= link_to "Shop Now", products_path, class: "btn btn-gold btn-lg px-5" %>
  </div>
</div>

<%# Categories Row %>
<div class="container my-5">
  <h2 class="section-title mb-4">Browse by Category</h2>
  <div class="row g-3">
    <% Category.all.each do |category| %>
      <div class="col-6 col-md-3">
        <%= link_to category_path(category), class: "text-decoration-none" do %>
          <div class="category-card text-center p-4">
            <div class="gold-text fs-4 mb-2">🎬</div>
            <div class="fw-bold text-white"><%= category.name %></div>
            <small class="text-muted"><%= category.products.count %> posters</small>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<%# Featured Products %>
<div class="container my-5">
  <h2 class="section-title mb-4">Featured Titles</h2>
  <div class="row g-4">
    <% @products.each do |product| %>
      <%= render "products/product_card", product: product %>
    <% end %>
  </div>
</div>