<div class="col-6 col-md-4 col-lg-3">
  <%= link_to product_path(product), class: "text-decoration-none" do %>
    <div class="product-card h-100">
      <div class="product-img-wrapper">
        <% if product.poster_url.present? %>
          <img src="<%= product.poster_url %>" class="product-img" alt="<%= product.title %>">
        <% elsif product.image.attached? %>
          <%= image_tag product.image, class: "product-img", alt: product.title %>
        <% else %>
          <div class="product-img-placeholder d-flex align-items-center justify-content-center">
            <span class="display-4">🎬</span>
          </div>
        <% end %>
        <div class="product-overlay">
          <span class="btn btn-gold btn-sm">View Details</span>
        </div>
      </div>
      <div class="product-info p-3">
        <h6 class="text-white mb-1" style="font-size:0.85rem; line-height:1.3"><%= product.title %></h6>
        <small class="text-muted"><%= product.category.name %></small>
        <div class="gold-text fw-bold mt-1">$<%= number_with_precision(product.price, precision: 2) %></div>
      </div>
    </div>
  <% end %>
</div>