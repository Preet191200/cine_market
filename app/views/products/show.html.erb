<div class="container mt-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb dark-breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
      <li class="breadcrumb-item"><%= link_to "Browse", products_path %></li>
      <li class="breadcrumb-item"><%= link_to @product.category.name, category_path(@product.category) %></li>
      <li class="breadcrumb-item active"><%= @product.title.truncate(40) %></li>
    </ol>
  </nav>
</div>
<div class="container my-5">
  <div class="row g-5">
    <div class="col-md-4">
      <% if @product.poster_url.present? %>
        <img src="<%= @product.poster_url %>" class="img-fluid rounded shadow" alt="<%= @product.title %>">
      <% elsif @product.image.attached? %>
        <%= image_tag @product.image, class: "img-fluid rounded shadow" %>
      <% else %>
        <div class="product-img-placeholder-lg d-flex align-items-center justify-content-center rounded">
          <span style="font-size: 8rem;">🎬</span>
        </div>
      <% end %>
    </div>
    <div class="col-md-8">
      <small class="gold-text text-uppercase letter-spacing"><%= @product.category.name %></small>
      <h1 class="text-white fw-bold mt-2 mb-3"><%= @product.title %></h1>
      <div class="gold-text fs-2 fw-bold mb-4">$<%= number_with_precision(@product.price, precision: 2) %></div>
      <p class="text-muted lh-lg"><%= @product.description %></p>
      <div class="mb-4">
        <% if @product.stock_quantity > 0 %>
          <span class="badge bg-success fs-6">✓ In Stock — <%= @product.stock_quantity %> available</span>
        <% else %>
          <span class="badge bg-danger fs-6">Out of Stock</span>
        <% end %>
      </div>

     <% if user_signed_in? %>
 <%= form_with url: add_to_cart_path(@product.id), method: :post, class: "d-inline" do |f| %>
    <%= f.number_field :quantity, value: 1, min: 1, max: 99, class: "form-control d-inline-block w-auto me-2", style: "background:#222; border-color:#444; color:white;" %>
    <%= f.submit "🛒 Add to Cart", class: "btn btn-gold btn-lg px-5" %>
  <% end %>
<% else %>
  <%= link_to "Sign in to Purchase", new_user_session_path, class: "btn btn-gold btn-lg px-5 me-3" %>
<% end %>

      <%# Comments section — coming soon %>
      <hr class="border-secondary mt-5">
      <h4 class="text-white mt-4 mb-3">Customer Reviews</h4>
      <% if user_signed_in? %>
        <p class="text-muted">Review functionality coming soon.</p>
      <% else %>
        <p class="text-muted"><%= link_to "Sign in", new_user_session_path, class: "gold-text" %> to leave a review.</p>
      <% end %>
    </div>
  </div>
</div>