<div class="container my-5">

  <%# Search Bar %>
  <div class="search-bar-wrapper mb-5">
    <%= form_with url: products_path, method: :get, data: { turbo: false } do |f| %>
      <div class="row g-2 align-items-center">
        <div class="col-md-6">
          <div class="input-group">
            <span class="input-group-text search-icon">🔍</span>
            <%= f.text_field :query,
                  value: params[:query],
                  placeholder: "Search movies, shows, directors...",
                  class: "form-control dark-input search-input" %>
          </div>
        </div>
        <div class="col-md-4">
          <%= f.select :category_id,
                options_from_collection_for_select(@categories, :id, :name, params[:category_id]),
                { prompt: "All Categories" },
                { class: "form-select dark-input" } %>
        </div>
        <div class="col-md-2">
          <%= f.submit "Search", class: "btn btn-gold w-100" %>
        </div>
      </div>
    <% end %>
  </div>

  <%# Results Header %>
  <% if params[:query].present? || params[:category_id].present? %>
    <div class="mb-4 d-flex justify-content-between align-items-center">
      <h2 class="section-title mb-0">
        <% if params[:query].present? %>
          Results for "<%= params[:query] %>"
        <% else %>
          <%= Category.find(params[:category_id]).name %>
        <% end %>
      </h2>
      <div class="d-flex align-items-center gap-3">
        <small class="text-muted"><%= @products.size %> title<%= @products.size == 1 ? "" : "s" %> found</small>
        <%= link_to "Clear Search", products_path, class: "btn btn-outline-secondary btn-sm" %>
      </div>
    </div>
  <% else %>
    <h2 class="section-title mb-4">All Titles</h2>
  <% end %>

  <%# No Results %>
  <% if @products.empty? %>
    <div class="text-center py-5">
      <div style="font-size:5rem">🎬</div>
      <h4 class="text-white mt-3">No titles found</h4>
      <p class="text-muted">Try a different keyword or browse all categories</p>
      <%= link_to "Browse All", products_path, class: "btn btn-gold mt-2" %>
    </div>
  <% else %>
    <div class="row g-4">
      <% @products.each do |product| %>
        <%= render "products/product_card", product: product %>
      <% end %>
    </div>
    <%# Pagination %>
<div class="d-flex justify-content-center mt-5">
  <%= paginate @products %>
</div>
  <% end %>
  <%# Filter buttons %>
<div class="d-flex gap-2 mb-4 flex-wrap">
  <%= link_to "All", products_path(query: params[:query], category_id: params[:category_id]),
        class: "btn btn-sm #{params[:filter].blank? ? 'btn-gold' : 'btn-outline-secondary'}" %>
  <%= link_to "New Arrivals", products_path(filter: "new", query: params[:query], category_id: params[:category_id]),
        class: "btn btn-sm #{params[:filter] == 'new' ? 'btn-gold' : 'btn-outline-secondary'}" %>
  <%= link_to "Recently Updated", products_path(filter: "updated", query: params[:query], category_id: params[:category_id]),
        class: "btn btn-sm #{params[:filter] == 'updated' ? 'btn-gold' : 'btn-outline-secondary'}" %>
</div>

</div>