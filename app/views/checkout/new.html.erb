<div class="container my-5">
  <h2 class="section-title mb-4">Checkout</h2>
  <div class="row g-4">

    <%# Address Form %>
    <div class="col-lg-7">
      <div class="cart-summary p-4 mb-4">
        <h5 class="text-white mb-4">Shipping Address</h5>
        <%= form_with url: checkout_confirm_path, method: :post do |f| %>
          <div class="mb-3">
            <label class="form-label text-muted">Street Address</label>
            <%= f.text_field :street, value: @address.street, class: "form-control dark-input", placeholder: "123 Main St", required: true %>
          </div>
          <div class="mb-3">
            <label class="form-label text-muted">City</label>
            <%= f.text_field :city, value: @address.city, class: "form-control dark-input", placeholder: "Winnipeg", required: true %>
          </div>
          <div class="mb-3">
            <label class="form-label text-muted">Postal Code</label>
            <%= f.text_field :postal_code, value: @address.postal_code, class: "form-control dark-input", placeholder: "R3C 1A1", required: true %>
          </div>
          <div class="mb-4">
            <label class="form-label text-muted">Province</label>
            <%= f.select :province_id,
                  options_from_collection_for_select(@provinces, :id, :name, @address.province_id),
                  { prompt: "Select your province" },
                  { class: "form-select dark-input", required: true } %>
          </div>
          <%= f.submit "Review Order →", class: "btn btn-gold w-100 btn-lg" %>
        <% end %>
      </div>
    </div>

    <%# Order Summary %>
    <div class="col-lg-5">
      <div class="cart-summary p-4">
        <h5 class="text-white mb-4">Your Order</h5>
        <% @cart_items.each do |item| %>
          <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="d-flex align-items-center gap-2">
              <% if item[:product].poster_url.present? %>
                <img src="<%= item[:product].poster_url %>" style="width:40px;height:55px;object-fit:cover;border-radius:3px;">
              <% end %>
              <div>
                <div class="text-white small"><%= item[:product].title.truncate(30) %></div>
                <small class="text-muted">Qty: <%= item[:quantity] %></small>
              </div>
            </div>
            <span class="gold-text">$<%= number_with_precision(item[:subtotal], precision: 2) %></span>
          </div>
        <% end %>
        <hr class="border-secondary">
        <div class="d-flex justify-content-between text-white fw-bold">
          <span>Subtotal</span>
          <span class="gold-text">$<%= number_with_precision(@total, precision: 2) %></span>
        </div>
        <small class="text-muted">Taxes calculated at next step</small>
      </div>
    </div>

  </div>
</div>