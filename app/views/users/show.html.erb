<div class="container my-5">
  <div class="row g-4">

    <%# Profile Info %>
    <div class="col-lg-4">
      <div class="cart-summary p-4 text-center">
        <div style="font-size:4rem">👤</div>
        <h4 class="text-white mt-3"><%= current_user.name %></h4>
        <p class="text-muted"><%= current_user.email %></p>
        <small class="text-muted">Member since <%= current_user.created_at.strftime("%B %Y") %></small>
        <hr class="border-secondary mt-3">
        <%= link_to "View My Orders", orders_path, class: "btn btn-gold w-100 mt-2" %>
        <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-outline-secondary w-100 mt-2" %>
      </div>
    </div>

    <%# Address %>
    <div class="col-lg-8">
      <div class="cart-summary p-4">
        <h5 class="text-white mb-4">Shipping Address</h5>
        <%= form_with url: update_address_path, method: :post, data: { turbo: false } do |f| %>
          <div class="mb-3">
            <label class="form-label text-muted">Street Address</label>
            <%= f.text_field :street, value: @address.street, class: "form-control dark-input", placeholder: "123 Main St" %>
          </div>
          <div class="row g-2 mb-3">
            <div class="col-md-6">
              <label class="form-label text-muted">City</label>
              <%= f.text_field :city, value: @address.city, class: "form-control dark-input", placeholder: "Winnipeg" %>
            </div>
            <div class="col-md-6">
              <label class="form-label text-muted">Postal Code</label>
              <%= f.text_field :postal_code, value: @address.postal_code, class: "form-control dark-input", placeholder: "R3C 1A1" %>
            </div>
          </div>
          <div class="mb-4">
            <label class="form-label text-muted">Province</label>
            <%= f.select :province_id,
                  options_from_collection_for_select(@provinces, :id, :name, @address.province_id),
                  { prompt: "Select province" },
                  { class: "form-select dark-input" } %>
          </div>
          <%= f.submit "Save Address", class: "btn btn-gold px-5" %>
        <% end %>
      </div>
    </div>

  </div>
</div>
