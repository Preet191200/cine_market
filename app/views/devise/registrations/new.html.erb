<div class="auth-wrapper d-flex align-items-center justify-content-center min-vh-100">
  <div class="auth-card p-5">
    <div class="text-center mb-4">
      <h2 class="text-white fw-bold"><span class="gold-text">CINE</span> MARKET</h2>
      <p class="text-muted">Create your account</p>
    </div>

    <%= form_with model: resource, as: resource_name, url: registration_path(resource_name), data: { turbo: false } do |f| %>
      <% if resource.errors.any? %>
        <div class="alert alert-danger">
          <% resource.errors.full_messages.each do |msg| %>
            <div><%= msg %></div>
          <% end %>
        </div>
      <% end %>

      <div class="mb-3">
        <label class="form-label text-muted">Full Name</label>
        <%= f.text_field :name, class: "form-control dark-input", placeholder: "John Doe", required: true %>
      </div>

      <div class="mb-3">
        <label class="form-label text-muted">Email</label>
        <%= f.email_field :email, class: "form-control dark-input", placeholder: "you@example.com", required: true %>
      </div>

      <div class="mb-3">
        <label class="form-label text-muted">Password</label>
        <%= f.password_field :password, class: "form-control dark-input", placeholder: "Minimum 6 characters", required: true %>
      </div>

      <div class="mb-4">
        <label class="form-label text-muted">Confirm Password</label>
        <%= f.password_field :password_confirmation, class: "form-control dark-input", placeholder: "Repeat password", required: true %>
      </div>

      <hr class="border-secondary mb-4">
      <p class="text-muted small mb-3">Optional: Save your shipping address</p>

      <div class="mb-3">
        <label class="form-label text-muted">Street Address</label>
        <%= f.fields_for :address, Address.new do |a| %>
          <%= a.text_field :street, class: "form-control dark-input", placeholder: "123 Main St" %>
        <% end %>
      </div>

      <div class="row g-2 mb-3">
        <div class="col-md-6">
          <label class="form-label text-muted">City</label>
          <%= f.fields_for :address, Address.new do |a| %>
            <%= a.text_field :city, class: "form-control dark-input", placeholder: "Winnipeg" %>
          <% end %>
        </div>
        <div class="col-md-6">
          <label class="form-label text-muted">Postal Code</label>
          <%= f.fields_for :address, Address.new do |a| %>
            <%= a.text_field :postal_code, class: "form-control dark-input", placeholder: "R3C 1A1" %>
          <% end %>
        </div>
      </div>

      <div class="mb-4">
        <label class="form-label text-muted">Province</label>
        <%= f.fields_for :address, Address.new do |a| %>
          <%= a.select :province_id,
                options_from_collection_for_select(Province.order(:name), :id, :name),
                { prompt: "Select province (optional)" },
                { class: "form-select dark-input" } %>
        <% end %>
      </div>

      <%= f.submit "Create Account", class: "btn btn-gold w-100 btn-lg" %>
    <% end %>

    <div class="text-center mt-4">
      <p class="text-muted small">Already have an account? <%= link_to "Sign in", new_user_session_path, class: "gold-text" %></p>
    </div>
  </div>
</div>