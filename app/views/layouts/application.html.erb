<!DOCTYPE html>
<html>
  <head>
    <title>Cine Market</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", media: "all" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top" id="main-nav">
      <div class="container">
        <a class="navbar-brand fw-bold" href="/">
          <span class="gold-text">CINE</span> MARKET
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-auto">
            <li class="nav-item">
              <%= link_to "Browse", products_path, class: "nav-link" %>
            </li>
            <% Category.all.each do |category| %>
              <li class="nav-item">
                <%= link_to category.name, category_path(category), class: "nav-link" %>
              </li>
            <% end %>
            <li class="nav-item">
  <%= link_to "Browse & Search", products_path, class: "nav-link" %>
</li>
          </ul>
        <% if user_signed_in? %>
  <li class="nav-item">
    <%= link_to "Browse & Search", products_path, class: "nav-link" %>
  </li>
  <li class="nav-item">
    <%= link_to "My Orders", orders_path, class: "nav-link" %>
  </li>
  <li class="nav-item">
    <%= link_to current_user.name, profile_path, class: "nav-link gold-text" %>
  </li>
  <li class="nav-item">
    <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-link" %>
  </li>
<% else %>
  <li class="nav-item">
    <%= link_to "Sign In", new_user_session_path, class: "nav-link" %>
  </li>
  <li class="nav-item">
    <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-gold ms-2" %>
  </li>
<% end %>
          <li class="nav-item ms-3">
 <%= link_to cart_path, class: "nav-link position-relative" do %>
    🛒 Cart
    <% if cart_count > 0 %>
      <span class="cart-badge"><%= cart_count %></span>
    <% end %>
  <% end %>
</li>
          </ul>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="alert alert-success alert-dismissible fade show m-0" role="alert">
        <%= notice %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>
    <% if alert %>
      <div class="alert alert-danger alert-dismissible fade show m-0" role="alert">
        <%= alert %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>

    <main>
      <%= yield %>
    </main>

    <footer class="footer mt-5 py-4">
      <div class="container text-center">
        <span class="gold-text fw-bold">CINE MARKET</span>
        <p class="text-muted small mt-1">© <%= Date.current.year %> Cine Market. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>