<div class="container my-5">
  <h2 class="section-title mb-4">My Orders</h2>
  <% if @orders.empty? %>
    <div class="text-center py-5">
      <div style="font-size:5rem">📦</div>
      <h4 class="text-white mt-3">No orders yet</h4>
      <%= link_to "Browse Titles", products_path, class: "btn btn-gold mt-3" %>
    </div>
  <% else %>
    <% @orders.each do |order| %>
      <div class="cart-item p-4 mb-3">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="text-white mb-1">Order #<%= order.id %></h6>
            <small class="text-muted"><%= order.created_at.strftime("%B %d, %Y") %></small>
          </div>
          <div class="text-end">
            <div class="gold-text fw-bold">$<%= number_with_precision(order.total_price, precision: 2) %></div>
            <span class="badge bg-<%= order.status == 'paid' ? 'success' : order.status == 'shipped' ? 'info' : 'warning' %>">
              <%= order.status.capitalize %>
            </span>
          </div>
        </div>
        <hr class="border-secondary">
        <div class="d-flex gap-2 flex-wrap">
          <% order.order_items.each do |item| %>
            <% if item.product.poster_url.present? %>
              <img src="<%= item.product.poster_url %>" style="width:40px;height:55px;object-fit:cover;border-radius:3px;" title="<%= item.product.title %>">
            <% end %>
          <% end %>
        </div>
        <div class="mt-3">
          <%= link_to "View Order Details", order_path(order), class: "btn btn-outline-secondary btn-sm" %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>